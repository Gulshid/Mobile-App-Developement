<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml
    Every Activity MUST be declared here or the app will crash.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.uiuserinterface">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.UIUserinterface">

        <!-- MAIN entry point of the app -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- LinearLayout demo screen -->
        <activity
            android:name=".LinearLayoutActivity"
            android:exported="false"
            android:label="LinearLayout Demo" />

        <!-- RelativeLayout demo screen -->
        <activity
            android:name=".RelativeLayoutActivity"
            android:exported="false"
            android:label="RelativeLayout Demo" />

    </application>
</manifest>